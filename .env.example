# Copy to .env and restart Vite + the API.

# Frontend → Express API
VITE_API_URL=http://localhost:4000

# Express → MongoDB (required for npm run dev:api)
# Put the database name in the path, or set MONGODB_DB.
MONGODB_URI=mongodb://127.0.0.1:27017/workout_hub

# Optional: override database name from URI path
# MONGODB_DB=workout_hub

# Optional: live AI recommendations (otherwise the API uses built-in templates)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
